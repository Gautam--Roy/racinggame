# Domain the traefik router will match, e.g. racing.example.com
RACING_DOMAIN=racing.example.com

# Traefik entrypoint to attach the router to (default: websecure)
TRAEFIK_ENTRYPOINT=websecure

# Traefik ACME cert resolver name (default: letsencrypt)
CERT_RESOLVER=letsencrypt

# Name of the external docker network traefik is attached to (default: traefik)
TRAEFIK_NETWORK=traefik
